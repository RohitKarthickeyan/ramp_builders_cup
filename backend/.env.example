# Copy to .env and fill in to enable real LLM-driven agents.
# Without a key, the app runs in deterministic MOCK mode (great for offline demos).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Force mock mode even if a key is present:
# USE_MOCK=1
# Speed up / slow down simulated vendor email latency (1 = realistic, 0.1 = fast demo):
# LATENCY_SCALE=1
